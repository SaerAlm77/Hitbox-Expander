end

workspace.DescendantAdded:Connect(processPart)

local dragging = false
local dragStart
local startPos
local targetPos = Panel.Position
local currentPos = Panel.Position

Panel.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = targetPos
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

UIS.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		targetPos = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)

RunService.RenderStepped:Connect(function(dt)
	local alpha = math.clamp(dt * 10, 0, 1)
	currentPos = UDim2.new(
		currentPos.X.Scale,
		currentPos.X.Offset + (targetPos.X.Offset - currentPos.X.Offset) * alpha,
		currentPos.Y.Scale,
		currentPos.Y.Offset + (targetPos.Y.Offset - currentPos.Y.Offset) * alpha
	)
	Panel.Position = currentPos
end)
