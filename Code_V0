local function looksLikeHitbox(part)
	if not part:IsA("BasePart") then return false end

	-- Reject any part belonging to a model that has a Humanoid
	local model = part:FindFirstAncestorOfClass("Model")
	if model and model:FindFirstChildOfClass("Humanoid") then return false end

	local name = part.Name:lower()
	if name:find("hitbox") then return true end
	if part.Transparency >= 0.99 then
		if not part.CanCollide then return true end
		local color = part.Color
		if color.R > 0.6 and color.G < 0.3 and color.B < 0.3 then return true end
	end
	return false
end

local function updateHitboxes()
	local count = 0
	for part in pairs(processed) do
		if part and part.Parent then count += 1 end
	end
	HitboxVal.Text = tostring(count)
end

-- Reapply current settings to all already-processed parts
local function reapplyToAll()
	for part, originalSize in pairs(processed) do
		if part and part.Parent then
			part.Size = originalSize * SIZE_MULTIPLIER
			part.Transparency = NEW_TRANSPARENCY
		end
	end
end

local function processPart(part)
	if part.Name == "HumanoidRootPart" then return end
	if processed[part] then return end
	if not looksLikeHitbox(part) then return end

	-- Store original size before any modification
	local originalSize = part.Size
	processed[part] = originalSize

	part.Size = originalSize * SIZE_MULTIPLIER
	part.Transparency = NEW_TRANSPARENCY
	part.CastShadow = false

	LastProcessedLabel.Text = part.Name
	updateHitboxes()
	print("[HitboxViz]", part:GetFullName())
end

SizeMinusBtn.MouseButton1Click:Connect(function()
	SIZE_MULTIPLIER = math.max(1, SIZE_MULTIPLIER - 1)
	SizeValueLabel.Text = tostring(SIZE_MULTIPLIER)
	reapplyToAll()
end)

SizePlusBtn.MouseButton1Click:Connect(function()
	SIZE_MULTIPLIER += 1
	SizeValueLabel.Text = tostring(SIZE_MULTIPLIER)
	reapplyToAll()
end)

TransMinusBtn.MouseButton1Click:Connect(function()
	NEW_TRANSPARENCY = math.max(0, math.round((NEW_TRANSPARENCY - TRANSPARENCY_STEP) * 10) / 10)
	TransValueLabel.Text = tostring(NEW_TRANSPARENCY)
	reapplyToAll()
end)

TransPlusBtn.MouseButton1Click:Connect(function()
	NEW_TRANSPARENCY = math.min(1, math.round((NEW_TRANSPARENCY + TRANSPARENCY_STEP) * 10) / 10)
	TransValueLabel.Text = tostring(NEW_TRANSPARENCY)
	reapplyToAll()
end)

for _, obj in ipairs(workspace:GetDescendants()) do
